---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'SNS動画テンプレートパック',
    description: 'Instagram・TikTok・サイネージ対応の3種セット。テキストと画像を差し替えるだけでプロ品質の動画を量産。',
    price: '¥4,980',
    tag: 'テンプレート',
    tagColor: 'bg-blue-500/20 text-blue-300',
    link: '#',
  },
  {
    name: '企業動画テンプレートパック',
    description: '研修・スライド・掛け合い動画の3種セット。企業案件で実績のあるプロ仕様テンプレート。',
    price: '¥9,800',
    tag: 'テンプレート',
    tagColor: 'bg-blue-500/20 text-blue-300',
    link: '#',
  },
  {
    name: 'コンプリートパック（全6種）',
    description: '全テンプレートをまとめたお得なセット。あらゆる動画制作ニーズに対応。',
    price: '¥12,800',
    originalPrice: '¥14,780',
    tag: 'お得セット',
    tagColor: 'bg-amber-500/20 text-amber-300',
    link: '#',
  },
  {
    name: 'AI動画制作ワークフローガイド',
    description: '非エンジニアでもプロ品質の動画を制作するための実践ガイド。50ページ超のPDF。',
    price: '¥2,980',
    tag: 'ガイド',
    tagColor: 'bg-green-500/20 text-green-300',
    link: '#',
  },
  {
    name: 'AIプロンプト集（動画制作特化）',
    description: 'Claude & Midjourney用の厳選プロンプト100選。コピペですぐ使える。',
    price: '¥1,980',
    tag: 'プロンプト',
    tagColor: 'bg-purple-500/20 text-purple-300',
    link: '#',
  },
  {
    name: 'Instagramリールテンプレート',
    description: '有料パックの品質を無料でお試し。セットアップガイド付き。商用利用OK。',
    price: '無料',
    tag: '無料サンプル',
    tagColor: 'bg-rose-500/20 text-rose-300',
    link: '#',
  },
];

const freeTools = [
  {
    name: 'OGP工房',
    description: 'SNSシェア用のOGP画像を無料で生成。6種類のデザインテンプレート。',
    link: '#',
  },
  {
    name: 'LINEスタンプメーカー',
    description: '画像をアップロードするだけ。背景透過＆LINE規格のZIPを自動生成。',
    link: '#',
  },
  {
    name: 'サムネ職人',
    description: 'AIがYouTubeサムネイルを自動生成。タイトルを入力するだけ。',
    link: '#',
  },
  {
    name: '見積書AI',
    description: 'プロジェクト概要を入力するだけでAIが見積書を自動作成。PDF出力対応。',
    link: '#',
  },
  {
    name: '件名マスター',
    description: 'AIがメールの件名を10パターン提案。開封率アップに。',
    link: '#',
  },
];
---

<Layout title="AI Creator Lab — AIクリエイターのためのテンプレート & ツール">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-gray-950/80 backdrop-blur-xl border-b border-gray-800/50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="#" class="text-xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
        AI Creator Lab
      </a>
      <div class="flex gap-6 text-sm text-gray-400">
        <a href="#products" class="hover:text-white transition">Products</a>
        <a href="#tools" class="hover:text-white transition">Free Tools</a>
        <a href="#about" class="hover:text-white transition">About</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-950/50 via-gray-950 to-purple-950/50"></div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <p class="text-blue-400 text-sm font-medium tracking-widest mb-4 uppercase">AI Creator Lab</p>
      <h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight">
        <span class="bg-gradient-to-r from-blue-300 via-purple-300 to-pink-300 bg-clip-text text-transparent">
          AIで、動画制作を革命する
        </span>
      </h1>
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed">
        プログラマティック動画テンプレート & AIツール活用ガイド。<br />
        非エンジニアでもプロ品質の動画を量産できる時代へ。
      </p>
      <a href="#products" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white font-bold rounded-full transition-all shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40">
        商品を見る
      </a>
    </div>
  </section>

  <!-- Products -->
  <section id="products" class="py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-blue-400 text-sm font-medium tracking-widest mb-3 uppercase">Products</p>
        <h2 class="text-4xl font-black mb-4">デジタルプロダクト</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Remotion動画テンプレート、AIワークフローガイド、プロンプト集</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <a href={product.link} class="group block bg-gray-900/50 border border-gray-800/50 rounded-2xl p-6 hover:border-blue-500/30 hover:bg-gray-900/80 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-center justify-between mb-4">
              <span class={`text-xs px-3 py-1 rounded-full font-medium ${product.tagColor}`}>
                {product.tag}
              </span>
            </div>
            <h3 class="text-lg font-bold mb-2 group-hover:text-blue-300 transition">{product.name}</h3>
            <p class="text-sm text-gray-400 mb-4 leading-relaxed">{product.description}</p>
            <div class="flex items-end gap-2">
              <span class={`text-2xl font-black ${product.price === '無料' ? 'text-rose-400' : 'bg-gradient-to-r from-blue-300 to-purple-300 bg-clip-text text-transparent'}`}>
                {product.price}
              </span>
              {product.originalPrice && (
                <span class="text-sm text-gray-500 line-through mb-1">{product.originalPrice}</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Free Tools -->
  <section id="tools" class="py-24 px-4 bg-gray-900/30">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-green-400 text-sm font-medium tracking-widest mb-3 uppercase">Free Tools</p>
        <h2 class="text-4xl font-black mb-4">無料AIツール</h2>
        <p class="text-gray-400 max-w-xl mx-auto">すべて無料で使えるWebツール。登録不要。</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {freeTools.map((tool) => (
          <a href={tool.link} class="group flex items-start gap-4 bg-gray-900/50 border border-gray-800/50 rounded-xl p-5 hover:border-green-500/30 hover:bg-gray-900/80 transition-all duration-300">
            <div class="shrink-0 w-10 h-10 bg-green-500/10 rounded-lg flex items-center justify-center">
              <span class="text-green-400 text-lg">&#9889;</span>
            </div>
            <div>
              <h3 class="font-bold mb-1 group-hover:text-green-300 transition">{tool.name}</h3>
              <p class="text-sm text-gray-400 leading-relaxed">{tool.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-24 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-purple-400 text-sm font-medium tracking-widest mb-3 uppercase">About</p>
      <h2 class="text-4xl font-black mb-8">AI Creator Lab について</h2>
      <p class="text-gray-400 leading-loose text-lg mb-8">
        AIツールを駆使して動画・Webコンテンツを制作するクリエイターが運営しています。<br />
        「非エンジニアでもプロ品質のコンテンツが作れる」をテーマに、<br />
        実際の制作現場で使っているテンプレートやノウハウを公開しています。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#products" class="px-8 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold rounded-full hover:from-blue-500 hover:to-purple-500 transition-all">
          商品一覧を見る
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-800/50 py-8 px-4">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <p>&copy; 2026 AI Creator Lab</p>
      <div class="flex gap-6">
        <a href="#products" class="hover:text-gray-300 transition">Products</a>
        <a href="#tools" class="hover:text-gray-300 transition">Free Tools</a>
        <a href="#about" class="hover:text-gray-300 transition">About</a>
      </div>
    </div>
  </footer>
</Layout>
